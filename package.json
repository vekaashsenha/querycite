{
    "name": "ai-visibility-auditor",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "cf:build": "opennextjs-cloudflare build",
        "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
        "cf:deploy:staging": "opennextjs-cloudflare build && opennextjs-cloudflare deploy -- --keep-vars",
        "cf:upload:staging": "opennextjs-cloudflare build && opennextjs-cloudflare upload -- --keep-vars",
        "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
    },
    "dependencies": {
        "@google/genai": "latest",
        "@opennextjs/cloudflare": "^1.20.1",
        "@supabase/supabase-js": "^2.108.2",
        "@tailwindcss/postcss": "latest",
        "cheerio": "latest",
        "next": "latest",
        "react": "latest",
        "react-dom": "latest"
    },
    "devDependencies": {
        "@types/node": "latest",
        "@types/react": "latest",
        "@types/react-dom": "latest",
        "eslint": "^9.39.4",
        "eslint-config-next": "latest",
        "tailwindcss": "latest",
        "typescript": "5.9.3",
        "wrangler": "^4.110.0"
    }
}
